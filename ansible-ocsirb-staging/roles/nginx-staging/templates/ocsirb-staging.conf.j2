# Ocsirb staging — managed by Ansible
# Served via cloudflared tunnel on staging.ocsirb.com
server {
    listen 80;
    server_name staging.ocsirb.com;

    root /var/www/html;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /assets/ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    gzip on;
    gzip_types text/plain text/css text/javascript application/javascript application/json image/svg+xml;
    gzip_min_length 1024;

    access_log /var/log/nginx/ocsirb-staging-access.log;
    error_log  /var/log/nginx/ocsirb-staging-error.log;
}
