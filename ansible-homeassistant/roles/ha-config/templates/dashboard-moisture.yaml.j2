#jinja2:variable_start_string:"[%", variable_end_string:"%]", block_start_string:"[#", block_end_string:"#]", comment_start_string:"[!", comment_end_string:"!]"
[! Plant moisture dashboard — managed by Ansible
   Source: ansible-homeassistant/roles/ha-config/templates/dashboard-moisture.yaml.j2
!]
title: Plant Moisture
views:
  - title: Plant Moisture
    path: moisture
    type: panel
    cards:
      - type: vertical-stack
        cards:
          # ── Tile sections: Moisture | Battery | Data Delay ────
          - type: horizontal-stack
            cards:
              # ── Current Moisture ──────────────────────────────
              - type: vertical-stack
                cards:
                  - type: markdown
                    content: "## Current Moisture"
[# for sensor in ha_wh51_sensors #]
                  - type: conditional
                    conditions:
                      - condition: numeric_state
                        entity: sensor.wh51_[% sensor.id %]_wh51_[% sensor.id %]_moisture
                        above: 18
                        below: 41
                    card:
                      type: tile
                      entity: sensor.wh51_[% sensor.id %]_wh51_[% sensor.id %]_moisture
                      name: "[% sensor.name | default(sensor.id) %]"
                      icon: mdi:water-percent
                      color: green
                  - type: conditional
                    conditions:
                      - condition: numeric_state
                        entity: sensor.wh51_[% sensor.id %]_wh51_[% sensor.id %]_moisture
                        above: 9
                        below: 19
                    card:
                      type: tile
                      entity: sensor.wh51_[% sensor.id %]_wh51_[% sensor.id %]_moisture
                      name: "[% sensor.name | default(sensor.id) %]"
                      icon: mdi:water-percent
                      color: amber
                  - type: conditional
                    conditions:
                      - condition: numeric_state
                        entity: sensor.wh51_[% sensor.id %]_wh51_[% sensor.id %]_moisture
                        below: 10
                    card:
                      type: tile
                      entity: sensor.wh51_[% sensor.id %]_wh51_[% sensor.id %]_moisture
                      name: "[% sensor.name | default(sensor.id) %]"
                      icon: mdi:water-percent
                      color: red
                  - type: conditional
                    conditions:
                      - condition: numeric_state
                        entity: sensor.wh51_[% sensor.id %]_wh51_[% sensor.id %]_moisture
                        above: 40
                    card:
                      type: tile
                      entity: sensor.wh51_[% sensor.id %]_wh51_[% sensor.id %]_moisture
                      name: "[% sensor.name | default(sensor.id) %]"
                      icon: mdi:water-percent
                      color: red
[# endfor #]
              # ── Battery ───────────────────────────────────────
              - type: vertical-stack
                cards:
                  - type: markdown
                    content: "## Battery"
[# for sensor in ha_wh51_sensors #]
                  - type: conditional
                    conditions:
                      - condition: numeric_state
                        entity: sensor.wh51_[% sensor.id %]_wh51_[% sensor.id %]_battery
                        above: 59
                    card:
                      type: tile
                      entity: sensor.wh51_[% sensor.id %]_wh51_[% sensor.id %]_battery
                      name: "[% sensor.name | default(sensor.id) %]"
                      icon: mdi:battery
                      color: green
                  - type: conditional
                    conditions:
                      - condition: numeric_state
                        entity: sensor.wh51_[% sensor.id %]_wh51_[% sensor.id %]_battery
                        above: 19
                        below: 60
                    card:
                      type: tile
                      entity: sensor.wh51_[% sensor.id %]_wh51_[% sensor.id %]_battery
                      name: "[% sensor.name | default(sensor.id) %]"
                      icon: mdi:battery-50
                      color: amber
                  - type: conditional
                    conditions:
                      - condition: numeric_state
                        entity: sensor.wh51_[% sensor.id %]_wh51_[% sensor.id %]_battery
                        below: 20
                    card:
                      type: tile
                      entity: sensor.wh51_[% sensor.id %]_wh51_[% sensor.id %]_battery
                      name: "[% sensor.name | default(sensor.id) %]"
                      icon: mdi:battery-alert
                      color: red
[# endfor #]
              # ── Data Delay ────────────────────────────────────
              - type: vertical-stack
                cards:
                  - type: markdown
                    content: "## Data Delay"
[# for sensor in ha_wh51_sensors #]
                  - type: conditional
                    conditions:
                      - condition: numeric_state
                        entity: sensor.wh51_[% sensor.id %]_data_delay
                        below: 300
                    card:
                      type: tile
                      entity: sensor.wh51_[% sensor.id %]_data_delay
                      name: "[% sensor.name | default(sensor.id) %]"
                      icon: mdi:clock-check-outline
                      color: green
                  - type: conditional
                    conditions:
                      - condition: numeric_state
                        entity: sensor.wh51_[% sensor.id %]_data_delay
                        above: 299
                        below: 1801
                    card:
                      type: tile
                      entity: sensor.wh51_[% sensor.id %]_data_delay
                      name: "[% sensor.name | default(sensor.id) %]"
                      icon: mdi:clock-alert-outline
                      color: amber
                  - type: conditional
                    conditions:
                      - condition: numeric_state
                        entity: sensor.wh51_[% sensor.id %]_data_delay
                        above: 1800
                    card:
                      type: tile
                      entity: sensor.wh51_[% sensor.id %]_data_delay
                      name: "[% sensor.name | default(sensor.id) %]"
                      icon: mdi:clock-remove-outline
                      color: red
[# endfor #]
          # ── 7 Day Moisture History (full width) ───────────────
[# for sensor in ha_wh51_sensors #]
          - type: history-graph
            title: "[% sensor.name | default(sensor.id) %]"
            hours_to_show: 168
            entities:
              - entity: sensor.wh51_[% sensor.id %]_wh51_[% sensor.id %]_moisture
                name: "Moisture %"
[# endfor #]
