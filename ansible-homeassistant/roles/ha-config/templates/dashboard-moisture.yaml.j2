#jinja2:variable_start_string:"[%", variable_end_string:"%]", block_start_string:"[#", block_end_string:"#]", comment_start_string:"[!", comment_end_string:"!]"
[! Plant moisture dashboard — managed by Ansible
   Source: ansible-homeassistant/roles/ha-config/templates/dashboard-moisture.yaml.j2

   Entity resolution: most WH51 sensors use Ansible-managed MQTT entities
   (sensor.wh51_<id>_wh51_<id>_moisture), but some were auto-discovered by
   MQTT and have different entity IDs.  The moisture_entity / battery_entity
   overrides in ha_wh51_sensors handle this.
!]
[! Macro to resolve the moisture entity ID for a sensor !]
[# macro moisture_eid(s) #][% s.moisture_entity | default('sensor.wh51_' ~ s.id ~ '_wh51_' ~ s.id ~ '_moisture') %][# endmacro #]
[# macro battery_eid(s) #][% s.battery_entity | default('sensor.wh51_' ~ s.id ~ '_wh51_' ~ s.id ~ '_battery') %][# endmacro #]
title: Plant Moisture
views:
  - title: Plant Moisture
    path: moisture
    type: sections
    sections:
      # ── Sensor Health ──────────────────────────────────────────
      - type: grid
        title: "Sensor Health"
        column_span: 4
        cards:
          - type: markdown
            content: >
              | Plant | Moisture | Battery | Last Seen |

              |:------|:--------:|:-------:|:----------|

              [# for sensor in ha_wh51_sensors #]
              | **[% sensor.name | default(sensor.id) %]** | {{ states('[% moisture_eid(sensor) %]') }}% | {{ states('[% battery_eid(sensor) %]') }}% | {% if states('sensor.wh51_[% sensor.id %]_last_seen') not in ['unknown', 'unavailable'] %}{{ relative_time(states.sensor.wh51_[% sensor.id %]_last_seen.last_updated) }} ago{% else %}**No data**{% endif %} |

              [# endfor #]

      # ── Current Readings ───────────────────────────────────────
      - type: grid
        title: "Current Moisture"
        column_span: 2
        cards:
[# for sensor in ha_wh51_sensors #]
          - type: tile
            entity: [% moisture_eid(sensor) %]
            name: "[% sensor.name | default(sensor.id) %]"
            icon: mdi:water-percent
            color: green
[# endfor #]

      # ── Battery Status ─────────────────────────────────────────
      - type: grid
        title: "Battery"
        column_span: 2
        cards:
[# for sensor in ha_wh51_sensors #]
          - type: tile
            entity: [% battery_eid(sensor) %]
            name: "[% sensor.name | default(sensor.id) %]"
            color: amber
[# endfor #]

      # ── 7 Day Moisture History ─────────────────────────────────
[# for sensor in ha_wh51_sensors #]
      - type: grid
        title: "[% sensor.name | default(sensor.id) %]"
        column_span: 2
        cards:
          - type: history-graph
            hours_to_show: 168
            entities:
              - entity: [% moisture_eid(sensor) %]
                name: "Moisture %"
[# endfor #]
