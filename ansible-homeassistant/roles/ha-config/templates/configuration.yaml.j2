#jinja2:variable_start_string:"[%", variable_end_string:"%]", block_start_string:"[#", block_end_string:"#]", comment_start_string:"[!", comment_end_string:"!]"
# Home Assistant configuration — managed by Ansible
# Do not edit on the HA host directly; changes will be overwritten.
# Source: ansible-homeassistant/roles/ha-config/templates/configuration.yaml.j2

default_config:

frontend:
  themes: !include_dir_merge_named themes

automation: !include automations.yaml
script: !include scripts.yaml
scene: !include scenes.yaml
sensor: !include_dir_merge_list sensors

# --- Prometheus metrics endpoint ---
# Exposes /api/prometheus for scraping by the monitoring stack.
# Filter to numeric sensors only; exclude noisy or unnecessary domains.
prometheus:
  namespace: homeassistant
  filter:
    include_domains:
      - sensor
      - binary_sensor
      - climate
      - weather
    exclude_entity_globs:
      - sensor.sm_*_app_*
      - sensor.*_geocoded_location

# --- MQTT sensors (modern HA ≥2022.6 format) ---
# WH51 soil sensors subscribe to moisture_proxy.py JSON topics.
mqtt:
  sensor: !include_dir_merge_list mqtt_sensors

# --- YAML-mode dashboards (managed by Ansible) ---
lovelace:
  mode: storage
  dashboards:
    dashboard-battery:
      mode: yaml
      title: Battery Status
      icon: mdi:battery
      show_in_sidebar: true
      filename: dashboards/battery.yaml
    dashboard-climate:
      mode: yaml
      title: Climate
      icon: mdi:thermometer
      show_in_sidebar: true
      filename: dashboards/climate.yaml
    dashboard-internet:
      mode: yaml
      title: Internet
      icon: mdi:web
      show_in_sidebar: true
      filename: dashboards/internet.yaml

[# if ha_light_groups | length > 0 #]
light:
[# for group in ha_light_groups #]
  - platform: group
    name: [% group.name %]
    unique_id: [% group.unique_id %]
    entities:
[# for entity in group.entities #]
      - [% entity %]
[# endfor #]
[# endfor #]
[# endif #]

template:
  - sensor:
      - name: "T9 HVAC Action"
        unique_id: t9_hvac_action
        state: >
          {{ state_attr('[% ha_thermostat_entity %]', 'hvac_action') }}
  - binary_sensor:
      - name: "HVAC Cooling"
        state: >
          {{ states('sensor.t9_hvac_action') == 'cooling' }}
      - name: "HVAC Heating"
        state: >
          {{ states('sensor.t9_hvac_action') == 'heating' }}
  - sensor:
      - name: "AC Delta T"
        unit_of_measurement: "°C"
        state_class: measurement
        state: >
          {% set return_raw = states('[% ha_ac_return_sensor %]') %}
          {% if return_raw in ['unavailable','unknown'] %}
            unavailable
          {% else %}
            {% set return_temp = return_raw | float(0) %}
            {% set ns = namespace(total=0, count=0) %}
[# for sensor in ha_ac_supply_sensors #]
            {% set v = states('[% sensor %]') %}
            {% if v not in ['unavailable','unknown'] and v | float(0) > 0 %}
              {% set ns.total = ns.total + v | float %}
              {% set ns.count = ns.count + 1 %}
            {% endif %}
[# endfor #]
            {% if ns.count > 0 %}
              {{ (return_temp - (ns.total / ns.count)) | round(1) }}
            {% else %}
              unavailable
            {% endif %}
          {% endif %}
  - sensor:
      - name: "Outdoor Temperature"
        unit_of_measurement: "°C"
        state_class: measurement
        device_class: temperature
        state: >
          {% set ns = namespace(total=0, count=0) %}
[# for sensor in ha_outdoor_temp_sensors #]
          {% set v = states('[% sensor %]') %}
          {% if v not in ['unavailable','unknown'] and v | float(0) != 0 %}
            {% set ns.total = ns.total + v | float %}
            {% set ns.count = ns.count + 1 %}
          {% endif %}
[# endfor #]
          {% if ns.count > 0 %}
            {{ (ns.total / ns.count) | round(1) }}
          {% else %}
            unavailable
          {% endif %}
  - sensor:
      - name: "Daily Cooling Hours"
        unique_id: daily_cooling_hours
        unit_of_measurement: "h"
        device_class: duration
        state_class: total_increasing
        state: >
          {{ states('sensor.ac_run_time_today') | float(0) }}
      - name: "Daily Heating Hours"
        unique_id: daily_heating_hours
        unit_of_measurement: "h"
        device_class: duration
        state_class: total_increasing
        state: >
          {{ states('sensor.heating_run_time_today') | float(0) }}
  - binary_sensor:
      - name: "Internet Up"
        unique_id: internet_up
        device_class: connectivity
        state: >
          {{ states('sensor.ping_google_wired') | float(0) > 0
             or states('sensor.ping_cloudflare_wired') | float(0) > 0
             or states('sensor.ping_google_wifi') | float(0) > 0 }}
      - name: "Internet WiFi Up"
        unique_id: internet_wifi_up
        device_class: connectivity
        state: >
          {{ states('sensor.ping_google_wifi') | float(0) > 0
             or states('sensor.ping_cloudflare_wifi') | float(0) > 0 }}
      - name: "Internet Ethernet Up"
        unique_id: internet_ethernet_up
        device_class: connectivity
        state: >
          {{ states('sensor.ping_google_wired') | float(0) > 0
             or states('sensor.ping_cloudflare_wired') | float(0) > 0 }}
  - sensor:
      - name: "Internet Uptime Today"
        unique_id: internet_uptime_today
        unit_of_measurement: "%"
        state_class: measurement
        icon: mdi:chart-line
        state: >
          {% set up   = state_attr('sensor.internet_up_today_raw', 'value') | float(0) %}
          {% set down = state_attr('sensor.internet_down_today_raw', 'value') | float(0) %}
          {% if (up + down) > 0 %}
            {{ ((up / (up + down)) * 100) | round(2) }}
          {% else %}
            100
          {% endif %}
  - sensor:
      - name: "Internet Uptime 7d"
        unique_id: internet_uptime_7d
        unit_of_measurement: "%"
        state_class: measurement
        icon: mdi:chart-line
        state: >
          {% set up   = state_attr('sensor.internet_up_7d_raw', 'value') | float(0) %}
          {% set down = state_attr('sensor.internet_down_7d_raw', 'value') | float(0) %}
          {% if (up + down) > 0 %}
            {{ ((up / (up + down)) * 100) | round(2) }}
          {% else %}
            100
          {% endif %}
# --- command_line sensors (modern HA ≥2023.8 format) ---
# The "sensor: platform: command_line" format is deprecated;
# these must be under the top-level command_line: key.
command_line:
[# for mon in ha_ping_monitors #]
  - sensor:
      name: "[% mon.name %]"
      unique_id: "[% mon.slug %]"
      command: "ping -c [% ha_ping_count %] -W 5 [# if mon.source_ip is defined #]-I [% mon.source_ip %] [# endif #][% mon.host %] 2>/dev/null | tail -1 | awk -F '/' '{printf \"%.1f\", $5}' || echo ''"
      unit_of_measurement: "ms"
      value_template: "{{ value | float(0) }}"
      scan_interval: [% ha_ping_scan_interval %]
[# endfor #]
  - sensor:
      name: "Packet Loss to Google"
      unique_id: packet_loss_google
      command: "ping -c 10 -W 5 8.8.8.8 2>/dev/null | grep -oP '\\d+(?=% packet loss)' || echo '100'"
      unit_of_measurement: "%"
      value_template: "{{ value | int(100) }}"
      scan_interval: 120
  - sensor:
      name: "DNS Resolution Time"
      unique_id: dns_resolution_time
      command: "dig @[% ha_dns_server %] $(head -c 8 /dev/urandom | od -An -tx1 | tr -d ' ').[% ha_dns_test_host %] +noall +stats 2>/dev/null | grep 'Query time' | awk '{print $4}' || echo ''"
      unit_of_measurement: "ms"
      value_template: "{{ value | int(0) }}"
      scan_interval: 120
  - sensor:
      name: "Ping Jitter"
      unique_id: ping_jitter
      command: "ping -c [% ha_jitter_count %] -W 5 [% ha_jitter_host %] 2>/dev/null | tail -1 | awk -F '/' '{printf \"%.1f\", $7}' || echo ''"
      unit_of_measurement: "ms"
      value_template: "{{ value | float(0) }}"
      scan_interval: 120
  - sensor:
      name: "External IP"
      unique_id: external_ip
      command: "curl -s -m 10 https://api.ipify.org 2>/dev/null || echo 'unavailable'"
      value_template: "{{ value }}"
      scan_interval: 3600
