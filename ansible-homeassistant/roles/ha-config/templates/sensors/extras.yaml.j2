#jinja2:variable_start_string:"[%", variable_end_string:"%]", block_start_string:"[#", block_end_string:"#]", comment_start_string:"[!", comment_end_string:"!]"
# Extra sensors — managed by Ansible
# Source: ansible-homeassistant/roles/ha-config/templates/sensors/extras.yaml.j2

# --- Temperature rate-of-change (derivative) sensors ---
[# for sensor in ha_temperature_sensors #]
  - platform: derivative
    source: [% sensor.source %]
    name: [% sensor.name %]
    unit_time: h
    round: 2
    unit: "°C/h"
    time_window: "00:05:00"

[# endfor #]

# --- Tides ---
  - platform: noaa_tides
    station_id: [% ha_noaa_tide_station_id %]

# --- HVAC runtime tracking ---
  - platform: history_stats
    name: AC Run Time Today
    entity_id: sensor.t9_hvac_action
    state: cooling
    type: time
    start: "{{ now().replace(hour=0, minute=0, second=0) }}"
    end: "{{ now() }}"

  - platform: history_stats
    name: Heating Run Time Today
    entity_id: sensor.t9_hvac_action
    state: heating
    type: time
    start: "{{ now().replace(hour=0, minute=0, second=0) }}"
    end: "{{ now() }}"

# --- Internet uptime tracking (history_stats) ---
# These feed the template sensors "Internet Uptime Today" and "Internet Uptime 7d"
  - platform: history_stats
    name: Internet Up Today Raw
    entity_id: binary_sensor.internet_up
    state: "on"
    type: time
    start: "{{ now().replace(hour=0, minute=0, second=0) }}"
    end: "{{ now() }}"

  - platform: history_stats
    name: Internet Down Today Raw
    entity_id: binary_sensor.internet_up
    state: "off"
    type: time
    start: "{{ now().replace(hour=0, minute=0, second=0) }}"
    end: "{{ now() }}"

  - platform: history_stats
    name: Internet Up 7d Raw
    entity_id: binary_sensor.internet_up
    state: "on"
    type: time
    start: "{{ now() - timedelta(days=7) }}"
    end: "{{ now() }}"

  - platform: history_stats
    name: Internet Down 7d Raw
    entity_id: binary_sensor.internet_up
    state: "off"
    type: time
    start: "{{ now() - timedelta(days=7) }}"
    end: "{{ now() }}"
