#jinja2:variable_start_string:"[%", variable_end_string:"%]", block_start_string:"[#", block_end_string:"#]", comment_start_string:"[!", comment_end_string:"!]"
[! Internet dashboard — managed by Ansible
   Source: ansible-homeassistant/roles/ha-config/templates/dashboard-internet.yaml.j2
!]
title: Internet
views:
  - title: Internet
    path: internet
    type: sections
    sections:
      # ── Status at a Glance ────────────────────────────────────
      - type: grid
        title: ""
        column_span: 4
        cards:
          - type: markdown
            content: >
              # {% if is_state('binary_sensor.internet_up', 'on') %}🟢 INTERNET UP{% else %}🔴 INTERNET DOWN{% endif %}


              {% if is_state('binary_sensor.internet_wifi_up', 'on') %}🟢{% else %}🔴{% endif %} WiFi
              &nbsp;&nbsp;&nbsp;
              {% if is_state('binary_sensor.internet_ethernet_up', 'on') %}🟢{% else %}🔴{% endif %} Ethernet

          - type: tile
            entity: sensor.internet_uptime_today
            name: "Uptime Today"
            icon: mdi:percent-circle-outline
            color: green

          - type: tile
            entity: sensor.internet_uptime_7d
            name: "Uptime 7 Days"
            icon: mdi:percent-circle
            color: green

          - type: tile
            entity: sensor.external_ip
            name: "Public IP"
            icon: mdi:earth
            color: blue-grey

      # ── Network Health ───────────────────────────────────────
      - type: grid
        title: "Network Health"
        column_span: 4
        cards:
          - type: tile
            entity: sensor.packet_loss_to_google
            name: "Packet Loss"
            icon: mdi:package-variant-closed-check
            color: green

          - type: tile
            entity: sensor.dns_resolution_time
            name: "DNS Lookup"
            icon: mdi:dns-outline
            color: cyan

          - type: tile
            entity: sensor.ping_jitter
            name: "Jitter"
            icon: mdi:sine-wave
            color: cyan

      # ── Wired Pings (end0) ──────────────────────────────────
      - type: grid
        title: "Wired Pings"
        column_span: 2
        cards:
[# for mon in ha_ping_monitors #]
[# if mon.group == 'wired' #]
          - type: tile
            entity: sensor.[% mon.entity_id | default(mon.slug) %]
            name: "[% mon.name | replace('Ping ', '') | replace(' Wired', '') %]"
            icon: mdi:ethernet
            color: cyan

[# endif #]
[# endfor #]

      # ── WiFi Pings (wlan0) ──────────────────────────────────
      - type: grid
        title: "WiFi Pings"
        column_span: 2
        cards:
[# for mon in ha_ping_monitors #]
[# if mon.group == 'wifi' #]
          - type: tile
            entity: sensor.[% mon.entity_id | default(mon.slug) %]
            name: "[% mon.name | replace('Ping ', '') | replace(' WiFi', '') %]"
            icon: mdi:wifi
            color: cyan

[# endif #]
[# endfor #]

      # ── Speed ────────────────────────────────────────────────
      - type: grid
        title: "Speed"
        column_span: 2
        cards:
          - type: gauge
            entity: sensor.speedtest_download
            name: "Download"
            min: 0
            max: 1000
            needle: true
            severity:
              green: 200
              yellow: 50
              red: 0
            unit: Mbit/s

          - type: gauge
            entity: sensor.speedtest_upload
            name: "Upload"
            min: 0
            max: 300
            needle: true
            severity:
              green: 50
              yellow: 20
              red: 0
            unit: Mbit/s

          - type: tile
            entity: sensor.speedtest_ping
            name: "SpeedTest Ping"
            icon: mdi:swap-vertical
            color: cyan

      # ── 24 h Wired Ping History ─────────────────────────────
      - type: grid
        title: "24 h Wired Latency"
        column_span: 4
        cards:
          - type: history-graph
            title: "Wired Round Trip Time (ms)"
            hours_to_show: 24
            entities:
[# for mon in ha_ping_monitors #]
[# if mon.group == 'wired' #]
              - entity: sensor.[% mon.entity_id | default(mon.slug) %]
                name: "[% mon.name | replace('Ping ', '') | replace(' Wired', '') %]"
[# endif #]
[# endfor #]

      # ── 24 h WiFi Ping History ──────────────────────────────
      - type: grid
        title: "24 h WiFi Latency"
        column_span: 4
        cards:
          - type: history-graph
            title: "WiFi Round Trip Time (ms)"
            hours_to_show: 24
            entities:
[# for mon in ha_ping_monitors #]
[# if mon.group == 'wifi' #]
              - entity: sensor.[% mon.entity_id | default(mon.slug) %]
                name: "[% mon.name | replace('Ping ', '') | replace(' WiFi', '') %]"
[# endif #]
[# endfor #]

      # ── 24 h Speed History ──────────────────────────────────
      - type: grid
        title: "24 h Speed History"
        column_span: 4
        cards:
          - type: statistics-graph
            title: "Download / Upload (Mbit/s)"
            entities:
              - entity: sensor.speedtest_download
                name: "Download"
              - entity: sensor.speedtest_upload
                name: "Upload"
            period: hour
            chart_type: line
            days_to_show: 1

      # ── 7 Day Availability ──────────────────────────────────
      - type: grid
        title: "7 Day Availability"
        column_span: 4
        cards:
          - type: history-graph
            title: "Internet Up / Down"
            hours_to_show: 168
            entities:
              - entity: binary_sensor.internet_up
                name: "Internet"
              - entity: binary_sensor.internet_wifi_up
                name: "WiFi"
              - entity: binary_sensor.internet_ethernet_up
                name: "Ethernet"

          - type: statistics-graph
            title: "Packet Loss (%)"
            entities:
              - entity: sensor.packet_loss_to_google
                name: "Google"
            period: hour
            chart_type: line
            days_to_show: 7
            stat_types:
              - max
              - mean

      # ── 7 Day Speed & Latency Trend ─────────────────────────
      - type: grid
        title: "7 Day Speed Trend"
        column_span: 4
        cards:
          - type: statistics-graph
            title: "Download / Upload (Mbit/s)"
            entities:
              - entity: sensor.speedtest_download
                name: "Download"
              - entity: sensor.speedtest_upload
                name: "Upload"
            period: hour
            chart_type: line
            days_to_show: 7

          - type: statistics-graph
            title: "Wired Ping Latency (ms)"
            entities:
[# for mon in ha_ping_monitors #]
[# if mon.group == 'wired' #]
              - entity: sensor.[% mon.entity_id | default(mon.slug) %]
                name: "[% mon.name | replace('Ping ', '') | replace(' Wired', '') %]"
[# endif #]
[# endfor #]
            period: hour
            chart_type: line
            days_to_show: 7
            stat_types:
              - mean
              - max
