#jinja2:variable_start_string:"[%", variable_end_string:"%]", block_start_string:"[#", block_end_string:"#]", comment_start_string:"[!", comment_end_string:"!]"
# Battery Status Dashboard — managed by Ansible
# Source: ansible-homeassistant/roles/ha-config/templates/dashboard-battery.yaml.j2

title: Battery Status
views:
  - title: All Batteries
    path: batteries
    icon: mdi:battery
    type: sections
    sections:

      # ================================================================
      # Climate & Environment Sensors
      # ================================================================
      - title: Climate Sensors
        type: grid
        cards:
[# for sensor in ha_battery_climate_sensors #]
          - type: tile
            entity: [% sensor.entity_id %]
            name: "[% sensor.name %]"
[# endfor #]

      # ================================================================
      # Zigbee Sensors (Presence, Motion)
      # ================================================================
      - title: Zigbee Sensors
        type: grid
        cards:
[# for sensor in ha_battery_zigbee_sensors #]
          - type: tile
            entity: [% sensor.entity_id %]
            name: "[% sensor.name %]"
[# endfor #]

      # ================================================================
      # Blinds
      # ================================================================
      - title: Blinds
        type: grid
        cards:
[# for sensor in ha_battery_blind_sensors #]
          - type: tile
            entity: [% sensor.entity_id %]
            name: "[% sensor.name %]"
[# endfor #]

      # ================================================================
      # Soil Moisture Sensors (WH51)
      # Battery % is computed in the MQTT sensor (rtl433_wh51.yaml.j2)
      # with device_class: battery for native HA coloring.
      # Entity IDs: HA doubles the unique_id prefix with the name slug,
      # giving sensor.wh51_<id>_wh51_<id>_battery
      # ================================================================
      - title: Soil Sensors (WH51)
        type: grid
        cards:
[# for sensor in ha_wh51_sensors #]
          - type: tile
            entity: sensor.wh51_[% sensor.id %]_wh51_[% sensor.id %]_battery
            name: "[% sensor.name | default('WH51 ' + sensor.id) %]"
[# endfor #]

      # ================================================================
      # Mobile Devices
      # ================================================================
      - title: Mobile Devices
        type: grid
        cards:
[# for sensor in ha_battery_mobile_sensors #]
          - type: tile
            entity: [% sensor.entity_id %]
            name: "[% sensor.name %]"
[# endfor #]
