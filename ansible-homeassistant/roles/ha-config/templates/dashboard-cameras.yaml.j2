title: Cameras
views:
  - title: Live Feeds
    path: live
    icon: mdi:cctv
    type: sections
    sections:

      - title: Panoptes
        type: grid
        cards:
          - type: picture-entity
            entity: camera.panoptes
            camera_view: live
            show_state: false
            show_name: true
