# Example Secret for portfolio email configuration
# This file is for reference only and should NOT be committed with real secrets
# 
# To create the secret in your cluster, first create a JSON file named email_config.json:
# {
#   "smtp_server": "smtp.gmail.com",
#   "smtp_port": 587,
#   "sender_email": "your-email@gmail.com",
#   "sender_password": "your-app-password",
#   "recipient_emails": ["recipient1@example.com", "recipient2@example.com"]
# }
#
# Then create the secret with:
# kubectl create secret generic portfolio-email-config \
#   --from-file=email_config.json \
#   -n portfolio

apiVersion: v1
kind: Secret
metadata:
  name: portfolio-email-config
  namespace: portfolio
type: Opaque
data:
  # email_config.json base64 encoded here
  # Use: cat email_config.json | base64 -w 0
  email_config.json: "e30="  # This is empty JSON: {}
