# Generated by Ansible — do not edit manually.

[server]
http_port = 3000
domain = {{ ansible_host }}

[security]
admin_user = {{ grafana_admin_user | default('admin') }}
admin_password = {{ grafana_admin_password | default('homelab') }}
disable_initial_admin_creation = false

[users]
allow_sign_up = false

[auth.anonymous]
enabled = false

[dashboards]
default_home_dashboard_path = /var/lib/grafana/dashboards/node-exporter.json
