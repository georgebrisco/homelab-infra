# Generated by Ansible from inventory — do not edit manually.
# Scrape targets are derived from the containers and physical_devices groups.

global:
  scrape_interval: 30s
  evaluation_interval: 30s

scrape_configs:
  # Prometheus itself
  - job_name: prometheus
    static_configs:
      - targets: ['localhost:9090']

  # All node_exporter targets from inventory
  # Convention: every host in 'containers' or 'physical_devices' runs node_exporter on :9100
  - job_name: node
    static_configs:
{% for host in (groups['containers'] | default([])) + (groups['physical_devices'] | default([])) %}
{% if hostvars[host]['ansible_host'] is defined %}
      - targets: ['{{ hostvars[host]['ansible_host'] }}:9100']
        labels:
          instance: '{{ host }}'
{% endif %}
{% endfor %}
