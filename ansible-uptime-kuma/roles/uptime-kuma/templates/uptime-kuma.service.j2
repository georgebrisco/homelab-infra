# Managed by Ansible — do not edit manually
[Unit]
Description=Uptime Kuma
After=network.target

[Service]
User={{ uptime_kuma_user }}
WorkingDirectory={{ uptime_kuma_install_dir }}
ExecStart=/usr/bin/node server/server.js --port={{ uptime_kuma_port }} --data-dir={{ uptime_kuma_data_dir }}
Restart=always
RestartSec=5
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
