# rtl_433 configuration — managed by Ansible
# Radio
frequency   {{ rtl433_frequency }}
sample_rate {{ rtl433_sample_rate }}
gain        {{ rtl433_gain }}

# Outputs — MQTT broker from shared group_vars
output mqtt://{{ mqtt_broker }}:{{ mqtt_port }},user={{ mqtt_user }},pass={{ mqtt_pass }},retain=0,devices=rtl_433/{{ rtl433_host_prefix }}/devices[/type][/model][/id]
output mqtt://{{ mqtt_broker }}:{{ mqtt_port }},user={{ mqtt_user }},pass={{ mqtt_pass }},retain=0,events=rtl_433/{{ rtl433_host_prefix }}/events

# Local log files (rotated by logrotate)
output json:{{ rtl433_log_dir }}/rtl_433.json
output log:{{ rtl433_log_dir }}/rtl_433.log

# Timestamp
report_meta time:unix
protocol {{ rtl433_protocol }}
