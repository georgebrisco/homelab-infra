# PhotoPrism environment — managed by Ansible
# Authentication
PHOTOPRISM_ADMIN_USER={{ photoprism_admin_user }}
PHOTOPRISM_ADMIN_PASSWORD={{ photoprism_admin_password }}
PHOTOPRISM_AUTH_MODE=password
PHOTOPRISM_PUBLIC=false

# Network / HTTP
PHOTOPRISM_HTTP_HOST=0.0.0.0
PHOTOPRISM_HTTP_PORT={{ photoprism_port }}
PHOTOPRISM_SITE_URL=http://photoprism:{{ photoprism_port }}/
PHOTOPRISM_DISABLE_TLS=true
PHOTOPRISM_DEFAULT_TLS=false
PHOTOPRISM_HTTP_COMPRESSION=gzip

# Features & AI
PHOTOPRISM_DISABLE_TENSORFLOW=false
PHOTOPRISM_DISABLE_FACES=false
PHOTOPRISM_DISABLE_CLASSIFICATION=false
PHOTOPRISM_DISABLE_VECTORS=false
PHOTOPRISM_DETECT_NSFW=false
PHOTOPRISM_UPLOAD_NSFW=true

# Paths & Storage
PHOTOPRISM_STORAGE_PATH={{ photoprism_storage_path }}
PHOTOPRISM_ORIGINALS_PATH={{ photoprism_originals_path }}
PHOTOPRISM_IMPORT_PATH={{ photoprism_import_path }}
PHOTOPRISM_BACKUP_PATH={{ photoprism_backup_path }}

# Database
PHOTOPRISM_DATABASE_DRIVER=sqlite
